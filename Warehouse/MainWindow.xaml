<Window x:Class="Warehouse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Warehouse"
        mc:Ignorable="d"
        Title="Управление складским хозяйством" Height="600" Width="1024"
        WindowStartupLocation="CenterScreen">
    <Window.CommandBindings>
        <CommandBinding Command="local:WindowCommands.Exit"              Executed="Exit_Executed"/>
        <CommandBinding Command="local:WindowCommands.GetProducts"       Executed="GetProducts_Executed"/>
        <CommandBinding Command="local:WindowCommands.GetOrders"         Executed="GetOrders_Executed"/>
        <CommandBinding Command="local:WindowCommands.GetWarehouses"     Executed="GetWarehouses_Executed"/>
        <CommandBinding Command="local:WindowCommands.WhAdd"             Executed="WhAdd_Executed"/>
        <CommandBinding Command="local:WindowCommands.WhEdit"            Executed="WhEdit_Executed"/>
        <CommandBinding Command="local:WindowCommands.WhDelete"          Executed="WhDelete_Executed"/>
        <CommandBinding Command="local:WindowCommands.AddProduct"        Executed="AddProduct_Executed"/>
        <CommandBinding Command="local:WindowCommands.EditProduct"       Executed="EditProduct_Executed"/>
        <CommandBinding Command="local:WindowCommands.RemoveProduct"     Executed="RemoveProduct_Executed"/>
        <CommandBinding Command="local:WindowCommands.AddOrder"          Executed="AddOrder_Executed"/>
        <CommandBinding Command="local:WindowCommands.EditOrder"         Executed="EditOrder_Executed"/>
        <CommandBinding Command="local:WindowCommands.RemoveOrder"       Executed="RemoveOrder_Executed"/>
        <CommandBinding Command="local:WindowCommands.ShowCategories"    Executed="ShowCategories_Executed"/>
        <CommandBinding Command="local:WindowCommands.ShowSuppliers"     Executed="ShowSuppliers_Executed"/>
        <CommandBinding Command="local:WindowCommands.ShowManufacturers" Executed="ShowManufacturers_Executed"/>
        <CommandBinding Command="local:WindowCommands.ImportProducts"    Executed="ImportProducts_Executed"/>
    </Window.CommandBindings>
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#7FFF00">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Command="local:WindowCommands.Exit"/>
            </MenuItem>
            <MenuItem Header="Склады">
                <MenuItem Header="Список складов"  Command="local:WindowCommands.GetWarehouses"/>
                <Separator/>
                <MenuItem Header="Добавить склад"  Command="local:WindowCommands.WhAdd"/>
                <MenuItem Header="Изменить склад"  Command="local:WindowCommands.WhEdit"/>
                <MenuItem Header="Удалить склад"   Command="local:WindowCommands.WhDelete"/>
                <Separator/>
                <MenuItem Header="Импорт товаров"  Command="local:WindowCommands.ImportProducts"/>
            </MenuItem>
            <MenuItem Header="Товары">
                <MenuItem Header="Открыть список товаров"   Command="local:WindowCommands.GetProducts"/>
                <Separator/>
                <MenuItem Header="Добавить описание товара" Command="local:WindowCommands.AddProduct"/>
                <MenuItem Header="Изменить описание товара" Command="local:WindowCommands.EditProduct"/>
                <MenuItem Header="Удалить описание товара"  Command="local:WindowCommands.RemoveProduct"/>
            </MenuItem>
            <MenuItem Header="Накладные">
                <MenuItem Header="Открыть список накладных" Command="local:WindowCommands.GetOrders"/>
                <Separator/>
                <MenuItem Header="Создать накладную"        Command="local:WindowCommands.AddOrder"/>
                <MenuItem Header="Изменить накладную"       Command="local:WindowCommands.EditOrder"/>
                <MenuItem Header="Удалить накладную"        Command="local:WindowCommands.RemoveOrder"/>
            </MenuItem>
            <MenuItem Header="Справочники">
                <MenuItem Header="Категории товаров" Command="local:WindowCommands.ShowCategories"/>
                <MenuItem Header="Поставщики"        Command="local:WindowCommands.ShowSuppliers"/>
                <MenuItem Header="Производители"     Command="local:WindowCommands.ShowManufacturers"/>
            </MenuItem>
        </Menu>
        <StatusBar DockPanel.Dock="Bottom" Background="#F0F0F0">
            <TextBlock x:Name="tbStatus" FontFamily="Verdana"
                       FontSize="14" HorizontalAlignment="Right"
                       Margin="10 0" FontWeight="Bold"/>
        </StatusBar>
        <Frame DockPanel.Dock="Right" x:Name="MainFrame"
               NavigationUIVisibility="Hidden" Background="White"/>
    </DockPanel>
</Window>