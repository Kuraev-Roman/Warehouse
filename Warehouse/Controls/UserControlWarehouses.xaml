<UserControl x:Class="Warehouse.Controls.UserControlWarehouses"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Warehouse.Controls"
             xmlns:local1="clr-namespace:Warehouse.Controls.Helpers"
             xmlns:local2="clr-namespace:Warehouse"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="999">

    <UserControl.Resources>
        <DataTemplate x:Key="listTemplate">
            <StackPanel Margin="4">
                <TextBlock FontFamily="Verdana" FontSize="14" Text="{Binding Path=WhName}" HorizontalAlignment="Left"/>
            </StackPanel>
        </DataTemplate>
        <local1:PriceConverter x:Key="PriceConv"/>
        <local1:DiscountBackgroundConverter x:Key="BgConv"/>
    </UserControl.Resources>

    <UserControl.CommandBindings>
        <CommandBinding Command="local2:WindowCommands.WhAdd"          Executed="WhAdd_Executed"/>
        <CommandBinding Command="local2:WindowCommands.WhEdit"         Executed="WhEdit_Executed"/>
        <CommandBinding Command="local2:WindowCommands.WhDelete"       Executed="WhDelete_Executed"/>
        <CommandBinding Command="local2:WindowCommands.ImportProducts" Executed="ImportProducts_Executed"/>
    </UserControl.CommandBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListBox x:Name="lbxWhList" Grid.Column="0"
                 ItemTemplate="{StaticResource listTemplate}"
                 SelectionChanged="lbxWhList_SelectionChanged">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Новый склад"    Command="local2:WindowCommands.WhAdd"/>
                    <MenuItem Header="Изменить склад" Command="local2:WindowCommands.WhEdit"/>
                    <MenuItem Header="Удалить склад"  Command="local2:WindowCommands.WhDelete"/>
                    <Separator/>
                    <MenuItem Header="Импорт товаров" Command="local2:WindowCommands.ImportProducts"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

        <GridSplitter Grid.Column="1" ShowsPreview="False" Width="3"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <DockPanel Grid.Column="2">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0 5 5 0"/>
                    <TextBox x:Name="TxtSearch" Width="250"
                             TextChanged="TxtSearch_TextChanged" Margin="0 5 10 0"/>
                    <TextBlock Text="Поставщик:" VerticalAlignment="Center" Margin="0 5 5 0"/>
                    <ComboBox x:Name="CmbSupplier" Width="150"
                              SelectionChanged="CmbSupplier_SelectionChanged" Margin="0 5 10 0"/>
                    <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0 5 5 0"/>
                    <ComboBox x:Name="CmbSort" Width="120"
                              SelectionChanged="CmbSort_SelectionChanged" Margin="0 5 10 0">
                        <ComboBoxItem Content="Без сортировки"/>
                        <ComboBoxItem Content="Остаток ↑"/>
                        <ComboBoxItem Content="Остаток ↓"/>
                    </ComboBox>
                    <Button x:Name="BtnAdd" Content="Добавить товар"
                            Visibility="Collapsed" Click="BtnAdd_Click" Margin="0 5 0 0"/>
                </StackPanel>

                <DataGrid x:Name="DgProducts" AutoGenerateColumns="False"
                          IsReadOnly="True" SelectionMode="Single"
                          Grid.Row="1" MouseDoubleClick="DgProducts_MouseDoubleClick"
                          ItemsSource="{Binding}">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background"
                                    Value="{Binding Converter={StaticResource BgConv}}"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Фото" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding PhotoPath}"
                                           Width="50" Height="50" Stretch="Uniform"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Наименование"
                                            Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Категория"
                                            Binding="{Binding Category.Name}" Width="160"/>
                        <DataGridTextColumn Header="Производитель"
                                            Binding="{Binding Manufacturer.Name}" Width="160"/>
                        <DataGridTextColumn Header="Поставщик"
                                            Binding="{Binding Supplier.Name}" Width="160"/>
                        <DataGridTemplateColumn Header="Цена" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource PriceConv}}"
                                               TextAlignment="Right"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Остаток"
                                            Binding="{Binding StockQuantity}" Width="70"/>
                        <DataGridTextColumn Header="Скидка %"
                                            Binding="{Binding DiscountPercent}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>