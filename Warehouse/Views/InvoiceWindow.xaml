<Window x:Class="Warehouse.Views.InvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Накладные" Height="600" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

   
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="Накладные" FontWeight="Bold" 
                       FontSize="14" Margin="0,0,0,5"/>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,5,0,0">
                <Button Content="Создать" Width="85" Margin="2" Click="BtnCreate_Click"/>
                <Button Content="Удалить" Width="85" Margin="2" Click="BtnDelete_Click"/>
                <Button Content="Провести" Width="85" Margin="2" Click="BtnConfirm_Click"/>
            </StackPanel>
            <ListBox x:Name="LbxInvoices" SelectionChanged="LbxInvoices_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Number}" FontWeight="Bold"/>
                            <TextBlock>
                                <Run Text="{Binding Date, StringFormat=dd.MM.yyyy}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding Type}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Проведена: "/>
                                <Run Text="{Binding IsConfirmed}"/>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

       
        <DockPanel Grid.Column="2">
            <TextBlock DockPanel.Dock="Top" Text="Состав накладной" 
                       FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,5,0,0">
                <Button Content="Добавить товар" Width="120" Margin="2" Click="BtnAddItem_Click"/>
                <Button Content="Удалить строку" Width="120" Margin="2" Click="BtnRemoveItem_Click"/>
            </StackPanel>
            <DataGrid x:Name="DgItems" AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Товар" Binding="{Binding Product.Name}" Width="*"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>